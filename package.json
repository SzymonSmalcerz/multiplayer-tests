{
  "name": "multiplayer-game",
  "version": "1.0.0",
  "description": "Multiplayer top-down game — Colyseus + Phaser 3",
  "main": "dist/server/index.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/bundle.js --platform=browser --target=es2020 --sourcemap",
    "build": "npm run build:server && npm run build:client",
    "start": "npm run build && node dist/server/index.js",
    "test": "vitest run",
    "dev": "concurrently \"tsc -p tsconfig.json --watch\" \"nodemon --watch dist/server --delay 1 dist/server/index.js\" \"esbuild src/client/main.ts --bundle --outfile=public/bundle.js --platform=browser --target=es2020 --watch\""
  },
  "dependencies": {
    "@colyseus/core": "^0.17.0",
    "@colyseus/schema": "^4.0.0",
    "@colyseus/sdk": "^0.17.0",
    "@colyseus/ws-transport": "^0.17.0",
    "express": "^5.0.0",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.0",
    "nodemon": "^3.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
